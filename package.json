{
	"name": "atm-sim",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"tauri:dev": "tauri dev --features debug",
		"tauri:build": "tauri build",
		"tauri": "tauri",
		"db:dev": "docker compose --env-file .env -f docker-compose.yml -f docker-compose.dev.yml up postgres",
		"server:dev": "cargo watch -w backend -x 'run -p backend'",
		"prod:start": "docker compose --env-file .env -f docker-compose.yml -f docker-compose.prod.yml up -d",
		"prod:stop": "docker compose --env-file .env -f docker-compose.yml -f docker-compose.prod.yml down",
		"format": "bun run format:js && bun run format:rust",
		"format:js": "biome format --write",
		"format:rust": "cd app/src-tauri && cargo fmt",
		"lint": "biome lint",
		"lint:fix": "biome lint --write",
		"vite:dev": "vite",
		"vite:build": "vue-tsc --noEmit && vite build",
		"vite:preview": "vite preview"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.2.2",
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/plugin-opener": "^2.5.3",
		"tailwindcss": "^4.2.2",
		"vue": "^3.5.31",
		"vue-router": "5.0.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@tauri-apps/cli": "^2.10.1",
		"@vitejs/plugin-vue": "^6.0.5",
		"biome": "^0.3.3",
		"mkcert": "^3.2.0",
		"typescript": "~6.0.2",
		"vite": "^8.0.3",
		"vue-tsc": "^3.2.6"
	},
	"trustedDependencies": [
		"core-js"
	]
}
