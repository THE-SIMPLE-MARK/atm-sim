{
	"name": "atm-sim",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"tauri": "tauri",
		"dev": "tauri dev --features debug",
		"backend:start": "docker compose up -d --build",
		"backend:stop": "docker compose down",
		"build": "tauri build",
		"lint": "biome lint",
		"lint:fix": "biome lint --write",
		"biome:format": "biome format --write",
		"rust:format": "cd app/src-tauri && cargo fmt",
		"format": "bun run biome:format && bun run rust:format",
		"vite:dev": "vite",
		"vite:build": "vue-tsc --noEmit && vite build",
		"vite:preview": "vite preview"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.2.2",
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/plugin-opener": "^2.5.3",
		"tailwindcss": "^4.2.2",
		"vue": "^3.5.31",
		"vue-router": "5.0.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@tauri-apps/cli": "^2.10.1",
		"@vitejs/plugin-vue": "^6.0.5",
		"biome": "^0.3.3",
		"mkcert": "^3.2.0",
		"typescript": "~6.0.2",
		"vite": "^8.0.3",
		"vue-tsc": "^3.2.6"
	},
	"trustedDependencies": [
		"core-js"
	]
}
