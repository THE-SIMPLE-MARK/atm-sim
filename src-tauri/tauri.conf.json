{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "ATM Simulator",
	"version": "0.1.0",
	"identifier": "com.the-simple-mark.atm-sim",
	"build": {
		"beforeDevCommand": "bun run vite:dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run vite:build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "ATM Simulator",
				"width": 800,
				"height": 800,
				"resizable": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
